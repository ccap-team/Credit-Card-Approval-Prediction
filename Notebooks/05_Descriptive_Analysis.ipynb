# ============================================================
# Credit Card Approval Prediction
# Descriptive Analysis
# ============================================================

# Import Libraries
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# ------------------------------------------------------------
# Load Dataset
# ------------------------------------------------------------
app = pd.read_csv("application_record.csv")

print("=" * 70)
print("Dataset Loaded Successfully")
print("=" * 70)

# ------------------------------------------------------------
# Basic Information
# ------------------------------------------------------------
print("\nDataset Shape")
print(app.shape)

print("\nColumn Names")
print(app.columns.tolist())

print("\nData Types")
print(app.dtypes)

# ------------------------------------------------------------
# Missing Values
# ------------------------------------------------------------
print("\nMissing Values")
print(app.isnull().sum())

# ------------------------------------------------------------
# Statistical Summary (Numerical Columns)
# ------------------------------------------------------------
print("\nNumerical Statistics")
print(app.describe())

# ------------------------------------------------------------
# Statistical Summary (Categorical Columns)
# ------------------------------------------------------------
print("\nCategorical Statistics")
print(app.describe(include='object'))

# ------------------------------------------------------------
# Mean, Median, Mode
# ------------------------------------------------------------
print("\nMean of Numerical Columns")
print(app.mean(numeric_only=True))

print("\nMedian of Numerical Columns")
print(app.median(numeric_only=True))

print("\nMode")
print(app.mode().iloc[0])

# ------------------------------------------------------------
# Variance
# ------------------------------------------------------------
print("\nVariance")
print(app.var(numeric_only=True))

# ------------------------------------------------------------
# Standard Deviation
# ------------------------------------------------------------
print("\nStandard Deviation")
print(app.std(numeric_only=True))

# ------------------------------------------------------------
# Minimum Values
# ------------------------------------------------------------
print("\nMinimum Values")
print(app.min(numeric_only=True))

# ------------------------------------------------------------
# Maximum Values
# ------------------------------------------------------------
print("\nMaximum Values")
print(app.max(numeric_only=True))

# ------------------------------------------------------------
# Percentiles
# ------------------------------------------------------------
print("\n25th Percentile")
print(app.quantile(0.25, numeric_only=True))

print("\n50th Percentile (Median)")
print(app.quantile(0.50, numeric_only=True))

print("\n75th Percentile")
print(app.quantile(0.75, numeric_only=True))

# ------------------------------------------------------------
# Correlation Matrix
# ------------------------------------------------------------
print("\nCorrelation Matrix")
print(app.corr(numeric_only=True))

# ------------------------------------------------------------
# Boxplot for Income
# ------------------------------------------------------------
plt.figure(figsize=(8,5))
sns.boxplot(x=app["AMT_INCOME_TOTAL"])
plt.title("Income Distribution")
plt.show()

# ------------------------------------------------------------
# Histogram for Income
# ------------------------------------------------------------
plt.figure(figsize=(8,5))
sns.histplot(app["AMT_INCOME_TOTAL"], bins=30, kde=True)
plt.title("Income Histogram")
plt.show()

print("\nDescriptive Analysis Completed Successfully.")
