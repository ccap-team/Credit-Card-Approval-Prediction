<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Credit Card Approval Prediction</title><link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}"></head><body><header class="top-bar"><div class="logo">SmartBridge</div></header><div class="container"><div class="card"><div class="header"><h1>Credit Card Approval Prediction</h1></div><form action="/result" method="POST"><div class="grid"><div class="input-box"><label>Gender</label><select name="CODE_GENDER"><option value="F">Female</option><option value="M">Male</option></select></div><div class="input-box"><label>Own Car</label><select name="FLAG_OWN_CAR"><option value="Y">Yes</option><option value="N">No</option></select></div><div class="input-box"><label>Own Real Estate</label><select name="FLAG_OWN_REALTY"><option value="Y">Yes</option><option value="N">No</option></select></div><div class="input-box"><label>Children</label><input type="number" name="CNT_CHILDREN" value="0"></div><div class="input-box"><label>Annual Income</label><input type="number" name="AMT_INCOME_TOTAL"></div><div class="input-box"><label>Income Type</label><select name="NAME_INCOME_TYPE"><option>Working</option><option>Commercial associate</option><option>Pensioner</option><option>State servant</option><option>Student</option></select></div><div class="input-box"><label>Education</label><select name="NAME_EDUCATION_TYPE"><option>Higher education</option><option>Secondary / secondary special</option><option>Incomplete higher</option><option>Lower secondary</option><option>Academic degree</option></select></div><div class="input-box"><label>Family Status</label><select name="NAME_FAMILY_STATUS"><option>Married</option><option>Single / not married</option><option>Civil marriage</option><option>Separated</option><option>Widow</option></select></div><div class="input-box"><label>Housing Type</label><select name="NAME_HOUSING_TYPE"><option>House / apartment</option><option>With parents</option><option>Municipal apartment</option><option>Office apartment</option><option>Co-op apartment</option><option>Rented apartment</option></select></div><div class="input-box"><label>Date of Birth</label><input type="date" id="dob"></div><div class="input-box"><label>Years Employed</label><input type="number" id="years_employed" min="0"></div><div class="input-box"><label>Occupation</label><select name="OCCUPATION_TYPE"><option>Laborers</option><option>Core staff</option><option>Managers</option><option>Drivers</option><option>Sales staff</option><option>High skill tech staff</option><option>Medicine staff</option><option>Security staff</option><option>Cooking staff</option><option>Cleaning staff</option><option>Private service staff</option><option>Low-skill Laborers</option><option>Waiters/barmen staff</option><option>Secretaries</option><option>Realty agents</option><option>HR staff</option><option>IT staff</option><option>Students</option><option>Unemployed</option><option>Others</option></select></div><div class="input-box"><label>Family Members</label><input type="number" id="family_members" name="CNT_FAM_MEMBERS" value="2"></div></div><input type="hidden" name="AGE" id="age"><input type="hidden" name="DAYS_BIRTH" id="days_birth"><input type="hidden" name="DAYS_EMPLOYED" id="days_employed"><input type="hidden" name="FLAG_MOBIL" value="1"><input type="hidden" name="FLAG_WORK_PHONE" value="0"><input type="hidden" name="FLAG_PHONE" value="0"><input type="hidden" name="FLAG_EMAIL" value="0"><input type="hidden" name="FAMILY_SIZE" id="family_size"><input type="hidden" name="MONTHS_BALANCE" value="-10"><div class="button-area"><button class="btn" type="submit">Predict</button></div></form></div></div><script>const d=document.getElementById("dob"),y=document.getElementById("years_employed"),f=document.getElementById("family_members");d.onchange=()=>{const b=new Date(d.value),t=new Date();let a=t.getFullYear()-b.getFullYear();const m=t.getMonth()-b.getMonth();if(m<0||(m===0&&t.getDate()<b.getDate()))a--;age.value=a;days_birth.value=-(a*365)};y.oninput=()=>days_employed.value=-(parseFloat(y.value||0)*365);f.oninput=()=>family_size.value=f.value;family_size.value=f.value;</script></body></html>
